PORT=3000

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id
# ID de la cuenta manager (MCC). Requerido si el token es de una cuenta administradora.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Pipedrive
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token
PIPEDRIVE_PIPELINE_ID=your_pipeline_id
PIPEDRIVE_FIELD_CALIFICACION_LEAD=your_field_key
PIPEDRIVE_FIELD_CALIFICACION_SQL=your_field_key
PIPEDRIVE_FIELD_ORIGEN_SQL=your_field_key

# Google Service Account / Search Console / GA4 / Sheets
# Usa GOOGLE_SERVICE_ACCOUNT_KEY (ruta a archivo) o GOOGLE_SERVICE_ACCOUNT_JSON (credenciales inline)
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.yoursite.com/
GSC_QUERY_FILTER=your_keyword_filter
GA4_PROPERTY_ID=your_ga4_property_id
GOOGLE_SHEETS_AUCTION_ID=your_google_sheet_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...
